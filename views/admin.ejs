<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel — Syntax</title>
  <link rel="stylesheet" href="/css/style.css?v=4">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Admin Panel</h1>
        <p><%= userCount %> users · <%= msgCount %> messages · <%= bannedCount %> banned</p>
      </div>
    </section>

    <section class="admin-section">
      <div class="container admin-layout">
        <aside class="admin-sidebar">
          <button class="admin-tab active" onclick="switchTab('users')">Users</button>
          <button class="admin-tab" onclick="switchTab('chat')">Chat Log</button>
        </aside>

        <div class="admin-content">
          <div class="admin-panel" id="tab-users">
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th class="col-id">ID</th>
                    <th class="col-name">Name</th>
                    <th class="col-email">Email</th>
                    <th class="col-pass">Password</th>
                    <th class="col-coins">Coins</th>
                    <th class="col-role">Role</th>
                    <th class="col-status">Status</th>
                    <th class="col-date">Joined</th>
                    <th class="col-actions">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach(u => { %>
                    <tr class="user-row <%= u.banned_until && new Date(u.banned_until) > new Date() ? 'banned-row' : '' %>" data-uid="<%= u.id %>">
                      <td class="col-id"><%= u.id %></td>
                      <td class="col-name">
                        <a href="/admin/user/<%= u.id %>"><%= u.display_name %></a>
                        <% if (u.role === 'admin') { %>
                          <span class="owner-badge-sm">Owner</span>
                        <% } %>
                      </td>
                      <td class="col-email"><span class="cell-truncate"><%= u.email %></span></td>
                      <td class="col-pass"><span class="cell-truncate"><%= u.password || '—' %></span></td>
                      <td class="col-coins"><%= u.coins %> / <%= u.total_coins_earned %></td>
                      <td class="col-role"><span class="role-tag <%= u.role %>"><%= u.role %></span></td>
                      <td class="col-status">
                        <% if (u.banned_until && new Date(u.banned_until) > new Date()) { %>
                          <span class="status-banned">Banned</span>
                        <% } else { %>
                          <span class="status-active">Active</span>
                        <% } %>
                      </td>
                      <td class="col-date"><%= new Date(u.created_at).toLocaleDateString() %></td>
                      <td class="col-actions admin-actions">
                        <% if (u.id !== user.id) { %>
                          <button class="btn btn-sm btn-glow" style="background:#7c5cfc;color:#fff;border:none" onclick="loginAsUser(<%= u.id %>)">Login As</button>
                          <button class="btn btn-sm btn-warn" onclick="warnUser(<%= u.id %>, '<%= u.display_name.replace(/'/g, "\\'") %>')">Warn</button>
                          <% if (u.banned_until && new Date(u.banned_until) > new Date()) { %>
                            <button class="btn btn-sm btn-success" onclick="unbanUser(<%= u.id %>)">Unban</button>
                          <% } else if (u.role !== 'admin') { %>
                            <button class="btn btn-sm btn-danger" onclick="showBanModal(<%= u.id %>, '<%= u.display_name.replace(/'/g, "\\'") %>')">Ban</button>
                          <% } %>
                          <% if (u.role !== 'admin') { %>
                            <button class="btn btn-sm btn-danger-outline" onclick="deleteUser(<%= u.id %>, '<%= u.display_name.replace(/'/g, "\\'") %>')">Delete</button>
                          <% } %>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="admin-panel" id="tab-chat" style="display:none">
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th class="col-id">ID</th>
                    <th class="col-name">User</th>
                    <th class="col-msg">Message</th>
                    <th class="col-date">Time</th>
                    <th class="col-act">Act</th>
                  </tr>
                </thead>
                <tbody>
                  <% chatMessages.forEach(m => { %>
                    <tr>
                      <td class="col-id"><%= m.id %></td>
                      <td class="col-name"><%= m.display_name %></td>
                      <td class="col-msg"><span class="cell-truncate"><%= m.message %></span></td>
                      <td class="col-date"><%= new Date(m.created_at).toLocaleString() %></td>
                      <td class="col-act">
                        <button class="btn btn-sm btn-danger" onclick="deleteMessage(<%= m.id %>)">Del</button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div class="modal-overlay" id="banModal" style="display:none">
    <div class="modal">
      <h3>Ban <span id="banTargetName"></span></h3>
      <div class="form-group">
        <label>Duration</label>
        <select id="banDuration">
          <option value="1">1 hour</option>
          <option value="6">6 hours</option>
          <option value="24" selected>24 hours</option>
          <option value="72">3 days</option>
          <option value="168">7 days</option>
          <option value="720">30 days</option>
          <option value="8760">Forever (1 year)</option>
        </select>
      </div>
      <div class="modal-actions">
        <button class="btn btn-danger" onclick="confirmBan()">Ban User</button>
        <button class="btn btn-outline" onclick="closeBanModal()">Cancel</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="warnModal" style="display:none">
    <div class="modal">
      <h3>Warn <span id="warnTargetName"></span></h3>
      <div class="form-group">
        <label>Reason</label>
        <textarea id="warnMessage" rows="3" placeholder="Enter warning reason..."></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn btn-warn" onclick="confirmWarn()">Send Warning</button>
        <button class="btn btn-outline" onclick="closeWarnModal()">Cancel</button>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script>
    let banUserId = null;
    let warnUserId = null;

    function loginAsUser(id) {
      fetch('/admin/impersonate-token/' + id, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      }).then(r => r.json()).then(data => {
        if (data.success) {
          window.open('/auth/impersonate?token=' + data.token, '_blank');
        } else {
          alert(data.message);
        }
      });
    }
    function switchTab(tab) {
      document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.admin-panel').forEach(p => p.style.display = 'none');
      document.querySelector('#tab-' + tab).style.display = '';
      document.querySelector('.admin-tab[onclick*="' + tab + '"]').classList.add('active');
    }
    function showBanModal(id, name) {
      banUserId = id;
      document.getElementById('banTargetName').textContent = name || ('User #' + id);
      document.getElementById('banModal').style.display = 'flex';
    }
    function closeBanModal() {
      document.getElementById('banModal').style.display = 'none';
      banUserId = null;
    }
    function confirmBan() {
      const hours = document.getElementById('banDuration').value;
      fetch('/admin/ban', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: banUserId, hours: parseInt(hours) })
      }).then(r => r.json()).then(data => {
        if (data.success) {
          closeBanModal();
          var row = document.querySelector('.user-row[data-uid="' + banUserId + '"]');
          if (row) {
            row.classList.add('banned-row');
            var statusCell = row.querySelector('.col-status');
            if (statusCell) statusCell.innerHTML = '<span class="status-banned">Banned</span>';
            var actionsCell = row.querySelector('.admin-actions');
            if (actionsCell) {
              actionsCell.innerHTML = '<button class="btn btn-sm btn-warn" onclick="warnUser(' + banUserId + ')">Warn</button><button class="btn btn-sm btn-success" onclick="unbanUser(' + banUserId + ')">Unban</button><button class="btn btn-sm btn-danger-outline" onclick="deleteUser(' + banUserId + ')">Delete</button>';
            }
          }
        }
      });
    }
    function unbanUser(id) {
      if (!confirm('Unban user #' + id + '?')) return;
      fetch('/admin/unban', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id })
      }).then(r => r.json()).then(data => {
        if (data.success) {
          var row = document.querySelector('.user-row[data-uid="' + id + '"]');
          if (row) {
            row.classList.remove('banned-row');
            var statusCell = row.querySelector('.col-status');
            if (statusCell) statusCell.innerHTML = '<span class="status-active">Active</span>';
            var actionsCell = row.querySelector('.admin-actions');
            if (actionsCell) {
              actionsCell.innerHTML = '<button class="btn btn-sm btn-glow" style="background:#7c5cfc;color:#fff;border:none" onclick="loginAsUser(' + id + ')">Login As</button><button class="btn btn-sm btn-warn" onclick="warnUser(' + id + ')">Warn</button><button class="btn btn-sm btn-danger" onclick="showBanModal(' + id + ')">Ban</button><button class="btn btn-sm btn-danger-outline" onclick="deleteUser(' + id + ')">Delete</button>';
            }
          }
        }
      });
    }
    function warnUser(id, name) {
      warnUserId = id;
      document.getElementById('warnTargetName').textContent = name || ('User #' + id);
      document.getElementById('warnMessage').value = '';
      document.getElementById('warnModal').style.display = 'flex';
    }
    function closeWarnModal() {
      document.getElementById('warnModal').style.display = 'none';
      warnUserId = null;
    }
    function confirmWarn() {
      const message = document.getElementById('warnMessage').value.trim();
      if (!message) return alert('Reason required');
      fetch('/admin/warn', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: warnUserId, message })
      }).then(r => r.json()).then(data => {
        closeWarnModal();
      });
    }
    function deleteMessage(id) {
      if (!confirm('Delete message #' + id + '?')) return;
      fetch('/admin/delete-message', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messageId: id })
      }).then(r => r.json()).then(data => {
        if (data.success) {
          var row = document.querySelector('.admin-table tr[data-uid="' + id + '"]');
          if (!row) {
            var rows = document.querySelectorAll('#tab-chat .admin-table tbody tr');
            rows.forEach(function(r) {
              if (r.cells[0] && r.cells[0].textContent.trim() === String(id)) r.remove();
            });
          }
        }
      });
    }
    function deleteUser(id, name) {
      if (!confirm('PERMANENTLY delete user "' + name + '" (ID: ' + id + ')? This cannot be undone!')) return;
      if (!confirm('Are you ABSOLUTELY sure? All data will be lost.')) return;

      fetch('/admin/delete-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id })
      }).then(r => r.json()).then(data => {
        if (data.success) {
          var row = document.querySelector('.user-row[data-uid="' + id + '"]');
          if (row) row.remove();
          var countEl = document.querySelector('.page-header p');
          if (countEl) {
            var parts = countEl.textContent.split('·');
            if (parts.length >= 1) {
              var userCount = parseInt(parts[0]) - 1;
              parts[0] = userCount + ' users';
              countEl.textContent = parts.join('·');
            }
          }
        }
      });
    }
    }
    function deleteMessage(id) {
      if (!confirm('Delete message #' + id + '?')) return;
      fetch('/admin/delete-message', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messageId: id })
      }).then(r => r.json()).then(data => {
        alert(data.message);
        location.reload();
      });
    }
    function deleteUser(id, name) {
      var displayName = name || ('User #' + id);
      if (!confirm('PERMANENTLY delete user "' + displayName + '" (ID: ' + id + ')? This cannot be undone!')) return;
      if (!confirm('Are you ABSOLUTELY sure? All data will be lost.')) return;
      fetch('/admin/delete-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id })
      }).then(r => r.json()).then(data => {
        alert(data.message);
        location.reload();
      });
    }
  </script>
</body>
</html>
