<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel — Syntax</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Admin Panel</h1>
        <p><%= userCount %> users · <%= msgCount %> messages · <%= bannedCount %> banned</p>
      </div>
    </section>

    <section class="admin-section">
      <div class="container">
        <div class="admin-tabs">
          <button class="admin-tab active" onclick="switchTab('users')">Users</button>
          <button class="admin-tab" onclick="switchTab('chat')">Chat Log</button>
        </div>

        <div class="admin-panel" id="tab-users">
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Coins</th>
                  <th>Role</th>
                  <th>Status</th>
                  <th>Joined</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(u => { %>
                  <tr class="<%= u.banned_until && new Date(u.banned_until) > new Date() ? 'banned-row' : '' %>">
                    <td><%= u.id %></td>
                    <td>
                      <a href="/admin/user/<%= u.id %>"><%= u.display_name %></a>
                      <% if (u.role === 'admin') { %>
                        <span class="owner-badge-sm">Owner</span>
                      <% } %>
                    </td>
                    <td><%= u.email %></td>
                    <td><%= u.coins %> / <%= u.total_coins_earned %></td>
                    <td><span class="role-tag <%= u.role %>"><%= u.role %></span></td>
                    <td>
                      <% if (u.banned_until && new Date(u.banned_until) > new Date()) { %>
                        <span class="status-banned">Banned until <%= new Date(u.banned_until).toLocaleString() %></span>
                      <% } else { %>
                        <span class="status-active">Active</span>
                      <% } %>
                    </td>
                    <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                    <td class="admin-actions">
                      <% if (u.id !== user.id) { %>
                        <button class="btn btn-sm btn-warn" onclick="warnUser(<%= u.id %>, '<%= u.display_name.replace(/'/g, "\\'") %>')">Warn</button>
                        <% if (u.banned_until && new Date(u.banned_until) > new Date()) { %>
                          <button class="btn btn-sm btn-success" onclick="unbanUser(<%= u.id %>)">Unban</button>
                        <% } else if (u.role !== 'admin') { %>
                          <button class="btn btn-sm btn-danger" onclick="showBanModal(<%= u.id %>, '<%= u.display_name.replace(/'/g, "\\'") %>')">Ban</button>
                        <% } %>
                        <% if (u.role !== 'admin') { %>
                          <button class="btn btn-sm btn-danger-outline" onclick="deleteUser(<%= u.id %>, '<%= u.display_name.replace(/'/g, "\\'") %>')">Delete</button>
                        <% } %>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="admin-panel" id="tab-chat" style="display:none">
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>User</th>
                  <th>Message</th>
                  <th>Time</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% chatMessages.forEach(m => { %>
                  <tr>
                    <td><%= m.id %></td>
                    <td><%= m.display_name %></td>
                    <td class="msg-preview"><%= m.message %></td>
                    <td><%= new Date(m.created_at).toLocaleString() %></td>
                    <td>
                      <button class="btn btn-sm btn-danger" onclick="deleteMessage(<%= m.id %>)">Delete</button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div class="modal-overlay" id="banModal" style="display:none">
    <div class="modal">
      <h3>Ban <span id="banTargetName"></span></h3>
      <div class="form-group">
        <label>Duration</label>
        <select id="banDuration">
          <option value="1">1 hour</option>
          <option value="6">6 hours</option>
          <option value="24" selected>24 hours</option>
          <option value="72">3 days</option>
          <option value="168">7 days</option>
          <option value="720">30 days</option>
          <option value="8760">Forever (1 year)</option>
        </select>
      </div>
      <div class="modal-actions">
        <button class="btn btn-danger" onclick="confirmBan()">Ban User</button>
        <button class="btn btn-outline" onclick="closeBanModal()">Cancel</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="warnModal" style="display:none">
    <div class="modal">
      <h3>Warn <span id="warnTargetName"></span></h3>
      <div class="form-group">
        <label>Reason</label>
        <textarea id="warnMessage" rows="3" placeholder="Enter warning reason..."></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn btn-warn" onclick="confirmWarn()">Send Warning</button>
        <button class="btn btn-outline" onclick="closeWarnModal()">Cancel</button>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script>
    let banUserId = null;
    let warnUserId = null;
    function switchTab(tab) {
      document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.admin-panel').forEach(p => p.style.display = 'none');
      document.querySelector('#tab-' + tab).style.display = '';
      document.querySelector('.admin-tab[onclick*="' + tab + '"]').classList.add('active');
    }
    function showBanModal(id, name) {
      banUserId = id;
      document.getElementById('banTargetName').textContent = name;
      document.getElementById('banModal').style.display = 'flex';
    }
    function closeBanModal() {
      document.getElementById('banModal').style.display = 'none';
      banUserId = null;
    }
    function confirmBan() {
      const hours = document.getElementById('banDuration').value;
      fetch('/admin/ban', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: banUserId, hours: parseInt(hours) })
      }).then(r => r.json()).then(data => {
        alert(data.message);
        location.reload();
      });
    }
    function unbanUser(id) {
      if (!confirm('Unban user #' + id + '?')) return;
      fetch('/admin/unban', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id })
      }).then(r => r.json()).then(data => {
        alert(data.message);
        location.reload();
      });
    }
    function warnUser(id, name) {
      warnUserId = id;
      document.getElementById('warnTargetName').textContent = name;
      document.getElementById('warnMessage').value = '';
      document.getElementById('warnModal').style.display = 'flex';
    }
    function closeWarnModal() {
      document.getElementById('warnModal').style.display = 'none';
      warnUserId = null;
    }
    function confirmWarn() {
      const message = document.getElementById('warnMessage').value.trim();
      if (!message) return alert('Reason required');
      fetch('/admin/warn', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: warnUserId, message })
      }).then(r => r.json()).then(data => {
        alert(data.message);
        location.reload();
      });
    }
    function deleteMessage(id) {
      if (!confirm('Delete message #' + id + '?')) return;
      fetch('/admin/delete-message', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messageId: id })
      }).then(r => r.json()).then(data => {
        alert(data.message);
        location.reload();
      });
    }
    function deleteUser(id, name) {
      if (!confirm('PERMANENTLY delete user "' + name + '" (ID: ' + id + ')? This cannot be undone!')) return;
      if (!confirm('Are you ABSOLUTELY sure? All data will be lost.')) return;
      fetch('/admin/delete-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id })
      }).then(r => r.json()).then(data => {
        alert(data.message);
        location.reload();
      });
    }
  </script>
</body>
</html>
