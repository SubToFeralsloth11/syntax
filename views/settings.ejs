<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Settings — Syntax' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Settings</h1>
      </div>
    </section>

    <section class="settings-section">
      <div class="container">
        <% if (message) { %>
          <div class="alert alert-success"><i data-lucide="check-circle"></i> <%= message %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error"><i data-lucide="alert-circle"></i> <%= error %></div>
        <% } %>

        <div class="settings-card">
          <h2><i data-lucide="user"></i> Profile</h2>
          <form action="/settings/profile" method="POST" enctype="multipart/form-data">
            <div class="settings-avatar">
              <img src="<%= avatarUrl(user.avatar) %>" alt="Avatar" class="avatar-preview" id="avatarPreview" onerror="this.src='/images/default-avatar.svg'">
              <label class="btn btn-sm" for="avatarUpload"><i data-lucide="image"></i> Change Photo</label>
              <input type="file" id="avatarUpload" name="avatar" accept="image/*" style="display:none">
            </div>

            <div class="form-group">
              <label for="display_name">Display Name</label>
              <input type="text" id="display_name" name="display_name" value="<%= user.display_name %>" maxlength="30">
            </div>

            <div class="form-group">
              <label>Email</label>
              <input type="text" value="<%= user.email %>" disabled class="input-disabled">
            </div>

            <div class="form-group">
              <label for="bio">Bio</label>
              <textarea id="bio" name="bio" maxlength="200" placeholder="Tell others about yourself..."><%= user.bio || '' %></textarea>
            </div>

            <button type="submit" class="btn btn-primary"><i data-lucide="save"></i> Save Changes</button>
          </form>
        </div>

        <div class="settings-card">
          <h2><i data-lucide="sliders-horizontal"></i> Preferences</h2>
          <div class="form-group">
            <label class="toggle-label">
              <input type="checkbox" id="rememberMe" <%= user.remember_me !== 0 ? 'checked' : '' %> onchange="toggleRemember(this)">
              <span>Stay logged in</span>
            </label>
            <p class="setting-hint">When disabled, you'll be logged out when you close your browser.</p>
          </div>
        </div>

        <div class="settings-card">
          <h2><i data-lucide="key-round"></i> Change Password</h2>
          <form action="/settings/password" method="POST">
            <div class="form-group">
              <label for="current">Current Password</label>
              <input type="password" id="current" name="current" required>
            </div>
            <div class="form-group">
              <label for="newpass">New Password</label>
              <input type="password" id="newpass" name="newpass" required minlength="4">
            </div>
            <div class="form-group">
              <label for="confirm">Confirm New Password</label>
              <input type="password" id="confirm" name="confirm" required minlength="4">
            </div>
            <button type="submit" class="btn btn-primary"><i data-lucide="lock"></i> Change Password</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script>
    document.getElementById('avatarUpload').addEventListener('change', function(e) {
      if (e.target.files && e.target.files[0]) {
        const reader = new FileReader();
        reader.onload = function(ev) {
          document.getElementById('avatarPreview').src = ev.target.result;
        };
        reader.readAsDataURL(e.target.files[0]);
      }
    });

    function toggleRemember(cb) {
      fetch('/settings/remember', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ remember_me: cb.checked ? '1' : '0' })
      });
    }
  </script>
</body>
</html>
