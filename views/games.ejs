<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Games — Syntax' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Games</h1>
        <p>Choose a game to play · visit pages to earn coins</p>
      </div>
    </section>

    <section class="games-list">
      <div class="container">
        <div class="game-grid">
          <% games.forEach(game => { %>
            <% const visited = visitedPaths.includes('/games/' + game.id) %>
            <% const played = playedIds.includes(game.id) %>
            <a href="/games/<%= game.id %>" class="game-card <%= game.status === 'coming-soon' ? 'coming-soon' : '' %>">
              <div class="game-thumbnail" style="background-image:url('<%= game.thumbnail %>');background-size:cover;background-position:center">
                <% if (!game.thumbnail || game.thumbnail.endsWith('.svg')) { %>
                  <div class="game-placeholder"><%= game.name[0] %></div>
                <% } %>
              </div>
              <div class="game-info">
                <h3><%= game.name %></h3>
                <p><%= game.description %></p>
                <div class="game-status">
                  <% if (game.status === 'coming-soon') { %>
                    <span class="badge badge-coming"><i data-lucide="clock"></i> Coming Soon</span>
                  <% } else { %>
                    <span class="badge badge-active"><i data-lucide="circle-dot"></i> Active</span>
                  <% } %>
                  <% if (visited) { %>
                    <span class="badge badge-visited"><i data-lucide="eye"></i> Visited</span>
                  <% } %>
                  <% if (played) { %>
                    <span class="badge badge-played"><i data-lucide="check"></i> Played</span>
                  <% } %>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/main.js"></script>
</body>
</html>
