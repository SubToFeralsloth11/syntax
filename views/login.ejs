<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Login — Syntax' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <div class="auth-page">
      <div class="auth-card">
        <h1>Login</h1>
        <% if (messages) { %>
          <div class="alert alert-error"><%= messages %></div>
        <% } %>
        <form action="/login" method="POST">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required>
          </div>
          <div class="form-group form-checkbox">
            <label>
              <input type="checkbox" name="remember" value="1">
              <span>Remember me</span>
            </label>
          </div>
          <button type="submit" class="btn btn-primary btn-full"><i data-lucide="log-in"></i>Login</button>
        </form>
        <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
        <div class="auth-divider">
          <span>or</span>
        </div>
        <a href="/auth/google" class="btn btn-google btn-full">Sign in with Google</a>
        <% } %>
        <p class="auth-link">Don't have an account? <a href="/signup">Sign up</a></p>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/main.js"></script>
</body>
</html>
