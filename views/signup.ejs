<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // Sign Up' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <div class="auth-page">
      <div class="auth-card">
        <h1>Sign Up</h1>
        <% if (referred) { %>
          <div class="ref-banner"><i data-lucide="party-popper"></i> You were referred! Sign up and you'll both earn <strong>100 coins</strong>.</div>
        <% } %>
        <% if (messages) { %>
          <div class="alert alert-error"><%= messages %></div>
        <% } %>
        <form action="/signup" method="POST">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="display_name">Display Name</label>
            <input type="text" id="display_name" name="display_name" placeholder="Optional">
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required minlength="6">
          </div>
          <button type="submit" class="btn btn-primary btn-full"><i data-lucide="user-plus"></i>Sign Up</button>
        </form>
        <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
        <div class="auth-divider">
          <span>or</span>
        </div>
        <a href="/auth/google" class="btn btn-google btn-full">Sign up with Google</a>
        <% } %>
        <p class="auth-link">Already have an account? <a href="/login">Login</a></p>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/main.js"></script>
</body>
</html>
