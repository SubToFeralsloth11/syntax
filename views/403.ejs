<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Forbidden — Syntax' }) %>
<body>
  <div class="error-wrapper" style="--err-grad: linear-gradient(135deg, var(--error), #ff2bd6)">
    <div class="error-page">
      <div class="error-code" style="background:linear-gradient(135deg,var(--error),#ff2bd6);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 30px rgba(255,85,102,0.4))">403</div>
      <div class="error-title">Access Denied</div>
      <div class="error-desc">// you do not have permission to view this page</div>
      <div class="error-actions">
        <a href="/" class="btn btn-primary"><i data-lucide="home"></i>Go Home</a>
      </div>
    </div>
  </div>
  <script>
    if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');
    if (window.lucide) lucide.createIcons();
  </script>
</body>
</html>
