<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // ' + profile.display_name }) %>
<body>
  <%- include('partials/header') %>
  <main>
    <section class="page-header">
      <div class="container">
        <h1><%= profile.display_name %><% if (profile.role === 'admin') { %> <span class="owner-badge-sm">Owner</span><% } %></h1>
        <p>Level <%= profile.level %> — <%= profile.coins %> coins</p>
      </div>
    </section>
    <section class="profile-page">
      <div class="container">
        <div class="profile-layout">
          <div class="profile-sidebar">
            <div class="profile-card">
              <div class="profile-avatar">
                <img src="<%= avatarUrl(profile.avatar) %>" alt="" class="avatar-profile" onerror="this.src='/images/default-avatar.svg'">
              </div>
              <% if (profile.equipped_title) { %><p class="equipped-title">"<%= profile.equipped_title %>"</p><% } %>
              <% if (profile.bio) { %><p class="profile-bio"><%= profile.bio %></p><% } %>
              <%- include('partials/xp-bar', { progress: lvl.progress, level: lvl.level, xp: lvl.xp }) %>
              <div class="profile-stats-mini">
                <%- include('partials/stat', { value: profile.coins, label: 'Coins', icon: '' }) %>
                <%- include('partials/stat', { value: profile.level, label: 'Level', icon: '' }) %>
                <%- include('partials/stat', { value: new Date(profile.created_at).toLocaleDateString(), label: 'Joined', icon: '' }) %>
                <%- include('partials/stat', { value: profile.last_active ? new Date(profile.last_active).toLocaleDateString() : '—', label: 'Last Active', icon: '' }) %>
              </div>
              <% if (profile.id !== user.id) { %>
                <div class="profile-actions">
                  <% if (isFriend) { %>
                    <button class="btn btn-sm btn-danger-outline" onclick="removeFriend(<%= profile.id %>)"><i data-lucide="user-minus"></i> Remove</button>
                    <button class="btn btn-sm btn-primary" onclick="window.location.href='/friends?dm=<%= profile.id %>'"><i data-lucide="message-circle"></i> Message</button>
                  <% } else if (friendRequest && friendRequest.status === 'pending' && friendRequest.user_id === user.id) { %>
                    <button class="btn btn-sm" disabled><i data-lucide="clock"></i> Request Sent</button>
                  <% } else if (friendRequest && friendRequest.status === 'pending') { %>
                    <button class="btn btn-sm btn-primary" onclick="acceptFriend(<%= friendRequest.id %>)"><i data-lucide="check"></i> Accept</button>
                  <% } else { %>
                    <button class="btn btn-sm btn-primary" onclick="addFriend(<%= profile.id %>)"><i data-lucide="user-plus"></i> Add Friend</button>
                  <% } %>
                  <a href="/trades?with=<%= profile.id %>" class="btn btn-sm"><i data-lucide="repeat"></i> Trade</a>
                </div>
              <% } %>
              <% if (inventory.length > 0) { %>
                <h3 style="margin:16px 0 8px;text-align:left"><i data-lucide="sparkles"></i> Equipped</h3>
                <% inventory.forEach(item => { %>
                  <div class="mini-equipped"><%= item.item_type === 'frame' ? '[Frame]' : item.item_type === 'badge' ? '[Badge]' : '[Title]' %> <%= item.item_name %></div>
                <% }) %>
              <% } %>
            </div>
          </div>
          <div class="profile-main">
            <% if (achievements.length > 0) { %>
              <div class="profile-section"><h2><i data-lucide="award"></i> Achievements</h2>
                <% achievements.forEach(ach => { %>
                  <div class="achievement-badge"><span class="ach-icon"><i data-lucide="award"></i></span><div><strong><%= ach.name %></strong><p><%= ach.description %></p></div></div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="profile-section"><h2><i data-lucide="award"></i> Achievements</h2>
                <%- include('partials/empty-state', { icon: 'award', title: 'No achievements yet', subtitle: '' }) %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script>
    function addFriend(id) { fetch('/friends/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({friendId:id})}).then(r=>r.json()).then(d=>{showNotification(d.message,d.success!==false);if(d.success||d.message)setTimeout(()=>location.reload(),800)}) }
    function removeFriend(id) { if(confirm('Remove friend?')){fetch('/friends/remove',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({friendId:id})}).then(r=>r.json()).then(d=>{showNotification(d.message,d.success!==false);if(d.success||d.message)setTimeout(()=>location.reload(),800)})} }
    function acceptFriend(id) { fetch('/friends/accept',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({requestId:id})}).then(r=>r.json()).then(d=>{showNotification(d.message,d.success!==false);if(d.success||d.message)setTimeout(()=>location.reload(),800)}) }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
