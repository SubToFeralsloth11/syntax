<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Page Not Found — Syntax' }) %>
<body>
  <div class="error-wrapper">
    <div class="error-page">
      <div class="error-code">404</div>
      <div class="error-title">Page Not Found</div>
      <div class="error-desc">// the page you requested does not exist or has been relocated</div>
      <div class="error-actions">
        <a href="/" class="btn btn-primary"><i data-lucide="home"></i>Go Home</a>
        <a href="/games" class="btn btn-outline"><i data-lucide="gamepad-2"></i>Browse Games</a>
      </div>
    </div>
  </div>
  <script>
    if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');
    if (window.lucide) lucide.createIcons();
  </script>
</body>
</html>
