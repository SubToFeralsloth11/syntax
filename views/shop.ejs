<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // Shop' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Shop</h1>
        <p>Spend your hard-earned coins</p>
      </div>
    </section>

    <section class="shop-section">
      <div class="container">
        <div class="mystery-box-card">
          <h2><i data-lucide="gift"></i> Mystery Box</h2>
          <p class="mb-desc">A mysterious gift box with over 50 possible items. What will you get?</p>
          <div class="mystery-box-preview" id="mysteryBoxPreview">
            <div class="gift-box-icon">
              <div class="gift-box-body"></div>
              <div class="gift-box-ribbon"></div>
              <div class="gift-box-bow"></div>
            </div>
          </div>
          <p class="mb-price">250 coins</p>
          <div class="mb-buttons">
            <button class="btn" onclick="showLootTable()"><i data-lucide="list"></i> Show All Items</button>
            <button class="btn btn-primary" onclick="buyMysteryBox()"><i data-lucide="shopping-bag"></i> Buy Mystery Box</button>
          </div>
        </div>

        <div class="shop-items-section">
          <h2>Profile Items</h2>
          <div class="shop-grid">
            <% shopItems.forEach(item => { %>
              <% const owned = ownedIds.includes(item.id) %>
              <div class="shop-item <%= owned ? 'owned' : '' %>">
                <div class="shop-item-icon">
                  <i data-lucide="<%= item.type === 'frame' ? 'square' : item.type === 'badge' ? 'medal' : 'quote' %>"></i>
                </div>
                <h3><%= item.name %></h3>
                <p class="shop-item-desc"><%= item.description %></p>
                <p class="shop-item-price"><%= item.price %> coins</p>
                <% if (owned) { %>
                  <button class="btn btn-sm" disabled><i data-lucide="check"></i> Owned</button>
                <% } else { %>
                  <button class="btn btn-sm btn-primary" onclick="buyShopItem(<%= item.id %>)"><i data-lucide="shopping-bag"></i> Buy</button>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div class="modal-overlay hidden" id="lootTableModal">
    <div class="modal" role="dialog" aria-modal="true" aria-label="Mystery box loot table">
      <div class="modal-header">
        <h2>Possible Mystery Box Items</h2>
        <button class="modal-close" onclick="hideLootTable()" aria-label="Close"><i data-lucide="x"></i></button>
      </div>
      <div class="modal-body">
        <p class="modal-subtitle"><%= mysteryBoxItems.length %> possible items — pure luck!</p>
        <div class="loot-grid" id="lootGrid"></div>
      </div>
    </div>
  </div>

  <div class="modal-overlay hidden" id="openBoxOverlay">
    <div class="open-box-container">
      <div class="gift-box-animated" id="giftBoxAnim">
        <div class="gift-box-lid" id="giftBoxLid">
          <div class="gift-box-lid-ribbon"></div>
        </div>
        <div class="gift-box-bottom" id="giftBoxBottom">
          <div class="gift-box-bottom-ribbon"></div>
          <div class="gift-box-bow-anim"></div>
        </div>
        <div class="gift-box-glow" id="giftBoxGlow"></div>
      </div>
      <div class="gift-result hidden" id="giftResult">
        <h2 id="giftResultTitle"></h2>
        <p id="giftResultDesc"></p>
        <button class="btn btn-primary" onclick="closeGiftBox()"><i data-lucide="check"></i> Nice!</button>
      </div>
      <canvas id="confettiCanvas" class="confetti-canvas hidden"></canvas>
    </div>
  </div>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/shop.js"></script>
  <script src="/js/gift-box.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
