<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // Lucky Wheel' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Lucky Wheel</h1>
        <p>Costs <%= spinCost %> coins per spin · win up to 1000 coins</p>
      </div>
    </section>

    <section class="wheel-section">
      <div class="container">
        <div class="wheel-card">
          <div class="wheel-wrapper">
            <canvas id="wheelCanvas"></canvas>
          </div>
          <div class="wheel-controls">
            <button class="btn btn-primary btn-lg" id="spinBtn" onclick="spinWheel()">
              <i data-lucide="disc-3"></i> SPIN (<%= spinCost %> coins)
            </button>
            <div class="wheel-balance">Balance: <strong id="wheelBalance"><%= userCoins %></strong> coins</div>
          </div>
          <div class="wheel-legend">
            <% const tierDots = { low: '#4fa8ff', mid: '#44dd88', high: '#ffae00', epic: 'var(--magenta)' }; %>
            <% const tierNames = { low: 'Low', mid: 'Mid', high: 'High', epic: 'Jackpot' }; %>
            <% Object.keys(tierDots).forEach(t => { %>
              <span class="legend-item"><span class="legend-dot" style="background:<%= tierDots[t] %>;color:<%= tierDots[t] %>"></span><%= tierNames[t] %></span>
            <% }) %>
          </div>
          <p class="wheel-hint" id="wheelHint">// click SPIN to try your luck //</p>
        </div>
      </div>
    </section>

    <section class="wheel-prizes">
      <div class="container">
        <h2 class="section-title">All Possible Outcomes</h2>
        <div class="prize-table">
          <div class="prize-col">
            <h3><i data-lucide="skull"></i> Losses</h3>
            <div class="prize-list" id="lossList"></div>
          </div>
          <div class="prize-col">
            <h3><i data-lucide="coins"></i> Wins</h3>
            <div class="prize-list" id="winList"></div>
          </div>
          <div class="prize-col">
            <h3><i data-lucide="zap"></i> Time Warps</h3>
            <div class="prize-list" id="warpList"></div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div id="wheelResultOverlay" class="result-overlay" style="display:none">
    <div class="result-card">
      <div class="result-glow"></div>
      <div class="result-content">
        <div class="result-label" id="resultLabel">You won</div>
        <div class="result-amount" id="resultAmount">0</div>
        <div class="result-sub" id="resultSub">coins!</div>
        <button class="btn btn-primary" onclick="closeResult()"><i data-lucide="check"></i> Nice!</button>
      </div>
    </div>
    <canvas id="confettiCanvas"></canvas>
  </div>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script>
    window.WHEEL_SEGMENTS = <%- JSON.stringify(segments) %>;
    window.SPIN_COST = <%= spinCost %>;

    (function() {
      const allSegs = window.WHEEL_SEGMENTS;
      const lossList = document.getElementById('lossList');
      const winList = document.getElementById('winList');
      const warpList = document.getElementById('warpList');
      if (!lossList) return;

      const losses = allSegs.filter(s => s.type === 'coins' && s.value < 0).sort((a,b) => b.value - a.value);
      const wins = allSegs.filter(s => s.type === 'coins' && s.value > 0).sort((a,b) => a.value - b.value);
      const warps = allSegs.filter(s => s.type !== 'coins');

      function renderList(items, container, isLoss) {
        items.forEach(s => {
          const div = document.createElement('div');
          div.className = 'prize-item ' + (isLoss ? 'loss' : 'win');
          if (s.value >= 100 || s.value <= -100) div.className += ' epic';
          else if (s.value >= 50 || s.value <= -50) div.className += ' high';
          else if (s.value >= 20 || s.value <= -20) div.className += ' mid';
          div.innerHTML = '<span class="prize-val">' + s.label.replace(' coins','') + '</span><span class="prize-desc">' + s.desc + '</span>';
          container.appendChild(div);
        });
      }

      renderList(losses, lossList, true);
      renderList(wins, winList, false);

      warps.forEach(s => {
        const div = document.createElement('div');
        div.className = 'prize-item warp';
        div.innerHTML = '<span class="prize-val">' + s.label + '</span><span class="prize-desc">' + s.desc + '</span>';
        warpList.appendChild(div);
      });
    })();
  </script>
  <script src="/js/wheel.js?v=3"></script>
  <script src="/js/main.js"></script>
</body>
</html>
