<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trivia — Syntax</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Trivia</h1>
        <p>Answer correctly to earn 25 coins! Resets every 20 minutes.</p>
      </div>
    </section>

    <section class="trivia-section">
      <div class="container">
        <div class="trivia-timer">
          Next question in: <strong id="countdown">--:--</strong>
        </div>
        <div class="trivia-card">
          <% if (answered) { %>
            <div class="trivia-result">
              <h2><%= correct ? 'Correct!' : 'Wrong!' %></h2>
              <p><%= correct ? 'You earned 25 coins! Come back after the timer resets for a new question.' : 'Better luck next round!' %></p>
              <a href="/" class="btn btn-primary">Back to Home</a>
            </div>
          <% } else if (!question) { %>
            <div class="trivia-loading">
              <h2>Loading question...</h2>
              <p>Please wait while we fetch a question.</p>
              <a href="/trivia" class="btn">Try Again</a>
            </div>
          <% } else { %>
            <div class="trivia-question">
              <div class="trivia-meta">
                <span class="badge badge-category"><%= question.category %></span>
                <span class="badge badge-difficulty"><%= question.difficulty %></span>
              </div>
              <h2><%- question.question %></h2>
              <div class="trivia-answers" id="trivia-answers">
                <% question.answers.forEach(ans => { %>
                  <button class="btn trivia-btn" onclick="submitTriviaAnswer('<%= ans.replace(/'/g, "\\'") %>')">
                    <%- ans %>
                  </button>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script>
    var nextReset = <%= nextReset %>;
    function updateTimer() {
      var remaining = Math.max(0, Math.floor((nextReset - Date.now()) / 1000));
      var min = Math.floor(remaining / 60);
      var sec = remaining % 60;
      document.getElementById('countdown').textContent = min + ':' + (sec < 10 ? '0' : '') + sec;
      if (remaining <= 0) {
        document.getElementById('countdown').textContent = 'Now!';
        <% if (answered) { %>
        location.reload();
        <% } %>
      }
    }
    updateTimer();
    setInterval(updateTimer, 1000);
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
