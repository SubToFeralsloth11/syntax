<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // Trivia' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Trivia</h1>
        <p>Answer correctly to earn 25 coins · resets every 20 minutes</p>
      </div>
    </section>

    <section class="trivia-section">
      <div class="container">
        <div class="trivia-timer">
          <i data-lucide="timer" style="width:14px;height:14px"></i> Next question in: <strong id="countdown">--:--</strong>
        </div>
        <div class="trivia-card">
          <% if (answered) { %>
            <div class="trivia-result">
              <h2><%= correct ? 'Correct!' : 'Wrong!' %></h2>
              <p><%= correct ? 'You earned 25 coins! Come back after the timer resets for a new question.' : 'Better luck next round!' %></p>
              <a href="/" class="btn btn-primary"><i data-lucide="home"></i> Back to Home</a>
            </div>
          <% } else if (!question) { %>
            <div class="trivia-loading">
              <h2><i data-lucide="loader-circle"></i> Loading question...</h2>
              <p>Please wait while we fetch a question.</p>
              <a href="/trivia" class="btn"><i data-lucide="refresh-cw"></i> Try Again</a>
            </div>
          <% } else { %>
            <div class="trivia-question">
              <div class="trivia-meta">
                <span class="badge badge-category"><i data-lucide="tag"></i> <%= question.category %></span>
                <span class="badge badge-difficulty"><i data-lucide="gauge"></i> <%= question.difficulty %></span>
              </div>
              <h2><%- question.question %></h2>
              <div class="trivia-answers" id="trivia-answers">
                <% question.answers.forEach(ans => { %>
                  <button class="btn trivia-btn" onclick="submitTriviaAnswer('<%= ans.replace(/'/g, "\\'") %>')">
                    <i data-lucide="chevron-right"></i>
                    <%- ans %>
                  </button>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script>
    var nextReset = <%= nextReset %>;
    function updateTimer() {
      var remaining = Math.max(0, Math.floor((nextReset - Date.now()) / 1000));
      var min = Math.floor(remaining / 60);
      var sec = remaining % 60;
      document.getElementById('countdown').textContent = min + ':' + (sec < 10 ? '0' : '') + sec;
      if (remaining <= 0) {
        document.getElementById('countdown').textContent = 'Now!';
        <% if (answered) { %>
        location.reload();
        <% } %>
      }
    }
    updateTimer();
    setInterval(updateTimer, 1000);
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
