<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // Earn' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Earn Coins</h1>
        <p>Balance: <strong class="highlight"><%= userCoins %></strong> coins</p>
      </div>
    </section>

    <section class="earn-section">
      <div class="container">
        <div class="earn-tabs">
          <button class="earn-tab active" data-tab="shop" onclick="switchEarnTab('shop',this)"><i data-lucide="gift"></i>Shop</button>
          <button class="earn-tab" data-tab="bank" onclick="switchEarnTab('bank',this)"><i data-lucide="landmark"></i>Bank</button>
          <button class="earn-tab" data-tab="trivia" onclick="switchEarnTab('trivia',this)"><i data-lucide="brain-circuit"></i>Trivia</button>
          <button class="earn-tab" data-tab="wheel" onclick="switchEarnTab('wheel',this)"><i data-lucide="disc-3"></i>Wheel</button>
          <button class="earn-tab" data-tab="lottery" onclick="switchEarnTab('lottery',this)"><i data-lucide="ticket"></i>Lottery</button>
        </div>

        <!-- Shop -->
        <div class="earn-panel" id="tab-shop">
          <div class="mystery-box-card" style="margin-bottom:20px">
            <h2><i data-lucide="gift"></i> Mystery Box</h2>
            <p class="mb-desc">50+ items · 250 coins each</p>
            <div class="mystery-box-preview" id="mysteryBoxPreview">
              <div class="gift-box-icon"><div class="gift-box-body"></div><div class="gift-box-ribbon"></div><div class="gift-box-bow"></div></div>
            </div>
            <p class="mb-price">250 coins</p>
            <div class="mb-buttons">
              <button class="btn" onclick="showLootTable()"><i data-lucide="list"></i> Show All Items</button>
              <button class="btn btn-primary" onclick="buyMysteryBoxFlow()"><i data-lucide="shopping-bag"></i> Buy Mystery Box</button>
            </div>
          </div>
          <h2 class="section-title">Profile Items</h2>
          <div class="shop-grid">
            <% shopItems.forEach(item => { %>
              <% const owned = ownedIds.includes(item.id) %>
              <div class="shop-item <%= owned ? 'owned' : '' %>">
                <div class="shop-item-icon"><i data-lucide="<%= item.type === 'frame' ? 'square' : item.type === 'badge' ? 'medal' : 'quote' %>"></i></div>
                <h3><%= item.name %></h3>
                <p class="shop-item-desc"><%= item.description %></p>
                <p class="shop-item-price"><%= item.price %> coins</p>
                <% if (owned) { %>
                  <button class="btn btn-sm" disabled><i data-lucide="check"></i> Owned</button>
                <% } else { %>
                  <button class="btn btn-sm btn-primary" onclick="buyShopItem(<%= item.id %>)"><i data-lucide="shopping-bag"></i> Buy</button>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Bank -->
        <div class="earn-panel" id="tab-bank" style="display:none">
          <h2 class="section-title"><i data-lucide="landmark"></i> Investment Plans</h2>
          <div class="bank-plans" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px">
            <div class="bank-plan-card"><h3>Conservative</h3><p>100 coins — 20% return in 24h</p><button class="btn btn-primary" onclick="invest('conservative')">Invest 100</button></div>
            <div class="bank-plan-card"><h3>Balanced</h3><p>250 coins — 40% return in 48h</p><button class="btn btn-primary" onclick="invest('balanced')">Invest 250</button></div>
            <div class="bank-plan-card"><h3>Aggressive</h3><p>500 coins — 75% return in 72h</p><button class="btn btn-primary" onclick="invest('aggressive')">Invest 500</button></div>
          </div>
          <% if (investments && investments.length > 0) { %>
            <h3 class="section-title" style="font-size:1rem"><i data-lucide="hourglass"></i> Your Investments</h3>
            <% investments.forEach(inv => { %>
              <div class="investment-row"><span><%= inv.plan %></span><span class="mono"><%= inv.amount %> coins</span><span class="mono">+<%= inv.profit %></span><span class="mono"><%= inv.claimed ? 'Claimed' : 'Active' %></span><% if (!inv.claimed) { %><button class="btn btn-sm btn-primary" onclick="claimInvestment(<%= inv.id %>)">Claim</button><% } %></div>
            <% }) %>
          <% } %>
        </div>

        <!-- Trivia -->
        <div class="earn-panel" id="tab-trivia" style="display:none">
          <div class="trivia-card">
            <p class="trivia-timer"><i data-lucide="timer" style="width:14px;height:14px"></i> Next question in: <strong id="countdown">--:--</strong></p>
            <% if (triviaDone) { %>
              <p>Already answered this round. Check back after the timer!</p>
            <% } else { %>
              <p>Answer correctly to earn 25 coins!</p>
            <% } %>
            <a href="/trivia" class="btn btn-primary" style="margin-top:12px"><i data-lucide="brain-circuit"></i> Open Full Trivia</a>
          </div>
        </div>

        <!-- Wheel -->
        <div class="earn-panel" id="tab-wheel" style="display:none">
          <div class="wheel-card">
            <div class="wheel-wrapper" style="max-width:300px;margin:0 auto">
              <canvas id="wheelCanvas"></canvas>
            </div>
            <div class="wheel-controls">
              <button class="btn btn-primary btn-lg" id="spinBtn" onclick="spinWheelInline()"><i data-lucide="disc-3"></i> SPIN (<%= spinCost %> coins)</button>
              <div class="wheel-balance">Balance: <strong id="wheelBalance"><%= userCoins %></strong> coins</div>
            </div>
            <p class="wheel-hint" id="wheelHint">// click SPIN to try your luck //</p>
          </div>
        </div>

        <!-- Lottery -->
        <div class="earn-panel" id="tab-lottery" style="display:none">
          <div class="lottery-jackpot-card" style="margin-bottom:16px">
            <span class="jackpot-label">Current Jackpot</span>
            <span class="jackpot-amount" id="jackpotAmount"><%= lotteryJackpot.toLocaleString() %></span>
            <span class="jackpot-sub">coins</span>
          </div>
          <div class="lottery-card">
            <div class="lottery-info" style="grid-template-columns:1fr 1fr">
              <div class="lottery-stat"><span class="lotto-stat-value">50</span><span class="lotto-stat-label">Coins/ticket</span></div>
              <div class="lottery-stat"><span class="lotto-stat-value">0.05%</span><span class="lotto-stat-label">Chance/ticket</span></div>
            </div>
            <div class="form-group"><label>Number of tickets</label><div class="ticket-input-row"><input type="number" id="ticketCount" value="1" min="1" max="500"><span class="ticket-cost" id="ticketCostDisplay">= 50 coins</span></div><p class="ticket-chance" id="chanceDisplay">Chance: 0.050%</p></div>
            <button class="btn btn-primary btn-full" id="buyBtn2" onclick="buyTicketsInline()"><i data-lucide="ticket"></i> Buy & Draw</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Gift box animation overlay -->
  <div class="modal-overlay hidden" id="openBoxOverlay">
    <div class="open-box-container">
      <div class="gift-box-animated" id="giftBoxAnim">
        <div class="gift-box-lid" id="giftBoxLid"><div class="gift-box-lid-ribbon"></div></div>
        <div class="gift-box-bottom" id="giftBoxBottom"><div class="gift-box-bottom-ribbon"></div><div class="gift-box-bow-anim"></div></div>
        <div class="gift-box-glow" id="giftBoxGlow"></div>
      </div>
      <div class="gift-result hidden" id="giftResult">
        <h2 id="giftResultTitle"></h2>
        <p id="giftResultDesc"></p>
        <button class="btn btn-primary" onclick="closeGiftBox()"><i data-lucide="check"></i> Nice!</button>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script>
    window.SPIN_COST = <%= spinCost %>;
    window.WHEEL_SEGMENTS = <%- JSON.stringify(wheelSegments) %>;
  </script>
  <script src="/js/wheel.js?v=3"></script>
  <script src="/js/gift-box.js?v=3"></script>
  <script>
    function switchEarnTab(tab, btn) {
      document.querySelectorAll('.earn-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.earn-panel').forEach(p => p.style.display = 'none');
      document.querySelector('#tab-' + tab).style.display = '';
      if (btn) btn.classList.add('active');
      if (tab === 'wheel') { if (typeof drawWheel === 'function') drawWheel(); }
    }

    function invest(plan) { fetch('/bank/invest',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({plan})}).then(r=>r.json()).then(d=>{showNotification(d.message||(d.success?'Invested!':'Failed'),d.success!==false);if(d.success)setTimeout(()=>location.reload(),800)}) }
    function claimInvestment(id) { fetch('/bank/claim',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({investmentId:id})}).then(r=>r.json()).then(d=>{showNotification(d.message||(d.success?'Claimed!':'Failed'),d.success!==false);if(d.success)setTimeout(()=>location.reload(),800)}) }
    function buyShopItem(id) { fetch('/shop/buy/'+id,{method:'POST'}).then(r=>r.json()).then(d=>{showNotification(d.message||(d.success?'Bought!':'Failed'),d.success!==false);if(d.success)setTimeout(()=>location.reload(),800)}) }

    function buyMysteryBoxFlow() {
      fetch('/shop/mystery-box/buy',{method:'POST'}).then(r=>r.json()).then(d=>{
        if (!d.success) return showNotification(d.message, false);
        document.getElementById('openBoxOverlay').classList.remove('hidden');
        var anim = document.getElementById('giftBoxAnim');
        anim.classList.add('shake');
        setTimeout(function(){anim.classList.remove('shake');anim.classList.add('glow-pulse')},800);
        setTimeout(function(){
          anim.style.display='none';
          document.getElementById('giftResult').classList.remove('hidden');
          fetch('/shop/mystery-box/open',{method:'POST'}).then(r=>r.json()).then(d2=>{
            document.getElementById('giftResultTitle').textContent = d2.item;
            document.getElementById('giftResultDesc').textContent = d2.coins > 0 ? '+'+d2.coins+' coins!' : '';
          });
        },1800);
      });
    }
    function closeGiftBox() {
      document.getElementById('openBoxOverlay').classList.add('hidden');
      document.getElementById('giftBoxAnim').style.display='';
      document.getElementById('giftResult').classList.add('hidden');
      location.reload();
    }

    function showLootTable() { var items=<%- JSON.stringify(mysteryBoxItems.map(i=>({name:i.name,type:i.type}))) %>;var html='';items.forEach(i=>html+='<div style="padding:6px 0;border-bottom:1px solid var(--border);font-size:0.85rem">'+i.name+'</div>');var d=document.createElement('div');d.className='modal-overlay';d.style.cssText='display:flex';d.innerHTML='<div class="modal" style="max-width:440px"><div class="modal-header"><h2>Loot Table</h2><button class="modal-close" onclick="this.closest(\'.modal-overlay\').remove()">&times;</button></div><div class="modal-body" style="max-height:70vh;overflow-y:auto">'+html+'</div></div>';d.onclick=function(e){if(e.target===d)d.remove()};document.body.appendChild(d);if(window.lucide)lucide.createIcons(); }

    function buyTicketsInline() {
      var count = parseInt(document.getElementById('ticketCount').value)||1;
      var btn = document.getElementById('buyBtn2');
      btn.disabled = true;
      fetch('/lottery/buy',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({count:count})}).then(r=>r.json()).then(d=>{
        if(d.success){document.getElementById('jackpotAmount').textContent=d.jackpot.toLocaleString();showNotification(d.won?('JACKPOT WINNER! +'+d.wonAmount+' coins!'):'No luck. Chance was '+d.chance+'%',d.won);if(d.won)startConfetti&&startConfetti();setTimeout(()=>location.reload(),1200)}
        else showNotification(d.message,false);
        btn.disabled=false;
      });
    }
    document.getElementById('ticketCount').addEventListener('input',function(){var c=parseInt(this.value)||1;document.getElementById('ticketCostDisplay').textContent='= '+(c*50)+' coins';document.getElementById('chanceDisplay').textContent='Chance: '+(c*0.05).toFixed(3)+'%'});

    var nextReset = <%= Math.floor((Math.floor(Date.now()/(20*60*1000))+1)*20*60*1000) %>;
    function updateTimer(){var r=Math.max(0,Math.floor((nextReset-Date.now())/1000));var el=document.getElementById('countdown');if(el)el.textContent=Math.floor(r/60)+':'+((r%60)<10?'0':'')+(r%60);if(r<=0){if(el)el.textContent='Now!';location.reload()}}updateTimer();setInterval(updateTimer,1000);

    function spinWheelInline() {
      if (typeof spinWheel === 'function') { spinWheel(); }
      else { showNotification('Wheel loading... try refreshing', false); }
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
