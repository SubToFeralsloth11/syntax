<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Chat — Syntax' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Chat</h1>
        <p><%= userCount %> users registered</p>
      </div>
    </section>

    <section class="chat-section">
      <div class="container">
        <div class="chat-card">
          <div class="chat-header">
            <span><i data-lucide="hash"></i> general</span>
            <span class="chat-online" id="chatOnline"><i data-lucide="wifi" style="width:14px;height:14px"></i> connected</span>
          </div>
          <div class="chat-messages" id="chatMessages">
            <% if (messages.length === 0) { %>
              <div class="chat-empty">// no messages yet. be the first //</div>
            <% } else { %>
              <% messages.forEach(m => { %>
                <div class="chat-msg" data-id="<%= m.id %>">
                  <span class="chat-user" data-userid="<%= m.user_id %>"><%= m.display_name %><% if (m.role === 'admin') { %> <span class="owner-badge-sm">Owner</span><% } %></span>
                  <span class="chat-time"><%= new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
                  <div class="chat-text"><%= m.message %></div>
                </div>
              <% }) %>
            <% } %>
          </div>
          <div class="chat-input-area">
            <div class="chat-mentions" id="chatMentions" style="display:none"></div>
            <form id="chatForm" autocomplete="off">
              <input type="text" id="chatInput" placeholder="Type a message... (@ to mention)" maxlength="500">
              <button type="submit" class="btn btn-primary"><i data-lucide="send"></i> Send</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/chat.js"></script>
</body>
</html>
