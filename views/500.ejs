<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Server Error — Syntax' }) %>
<body>
  <div class="error-wrapper">
    <div class="error-page">
      <div class="error-code" style="background:linear-gradient(135deg,#ff5566,#ff8c1a);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 30px rgba(255,85,102,0.4))">500</div>
      <div class="error-title">Something Went Wrong</div>
      <div class="error-desc">// our server encountered an unexpected error. try refreshing or come back later.</div>
      <div class="error-actions">
        <button class="btn btn-primary" onclick="location.reload()"><i data-lucide="refresh-cw"></i>Refresh Page</button>
        <a href="/" class="btn btn-outline"><i data-lucide="home"></i>Go Home</a>
      </div>
    </div>
  </div>
  <script>
    if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');
    if (window.lucide) lucide.createIcons();
  </script>
</body>
</html>
