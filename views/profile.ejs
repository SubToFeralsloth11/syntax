<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: user.display_name + ' — Profile' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="profile-page">
      <div class="container">
        <div class="profile-layout">
          <div class="profile-sidebar">
            <div class="profile-card">
              <div class="profile-avatar">
                <img src="<%= avatarUrl(user.avatar) %>" alt="<%= user.display_name %>" class="avatar-profile" onerror="this.src='/images/default-avatar.svg'">
              </div>
              <h2><%= user.display_name %></h2>
              <% if (user.role === 'admin') { %>
                <span class="owner-badge">Owner</span>
              <% } %>
              <% if (user.equipped_title) { %>
                <p class="equipped-title">"<%= user.equipped_title %>"</p>
              <% } %>
              <% if (user.bio) { %>
                <p class="profile-bio"><%= user.bio %></p>
              <% } %>
              <div class="profile-stats-mini">
                <%- include('partials/stat', { value: user.coins, label: 'Coins', icon: '' }) %>
                <%- include('partials/stat', { value: totalCheckins, label: 'Check-ins', icon: '' }) %>
                <%- include('partials/stat', { value: totalVisits, label: 'Visited', icon: '' }) %>
                <%- include('partials/stat', { value: totalPlays, label: 'Played', icon: '' }) %>
              </div>
              <div class="profile-achievements">
                <h3>Achievements</h3>
                <% if (achievements.length === 0) { %>
                  <%- include('partials/empty-state', { icon: 'award', title: 'No achievements yet', subtitle: '' }) %>
                <% } else { %>
                  <% achievements.slice(0, 5).forEach(ach => { %>
                    <div class="achievement-badge">
                      <span class="ach-icon"><i data-lucide="award"></i></span>
                      <div>
                        <strong><%= ach.name %></strong>
                        <p><%= ach.description %></p>
                      </div>
                    </div>
                  <% }) %>
                  <% if (achievements.length > 5) { %>
                    <p class="more-achievements">+<%= achievements.length - 5 %> more</p>
                  <% } %>
                <% } %>
              </div>
            </div>
          </div>

          <div class="profile-main">
            <div class="profile-section">
              <h2><i data-lucide="backpack"></i> Inventory</h2>
              <% if (inventory.length === 0) { %>
                <%- include('partials/empty-state', { icon: 'package-open', title: 'Your inventory is empty', subtitle: 'Try opening a mystery box in the Shop!' }) %>
              <% } else { %>
                <div class="inventory-grid">
                  <% inventory.forEach(item => { %>
                    <div class="inventory-item <%= item.equipped ? 'equipped' : '' %>" data-id="<%= item.id %>" data-type="<%= item.item_type %>">
                      <div class="item-icon">
                        <i data-lucide="<%= item.item_type === 'frame' ? 'square' : item.item_type === 'badge' ? 'medal' : 'quote' %>"></i>
                      </div>
                      <div class="item-name"><%= item.item_name %></div>
                      <% if (item.equipped) { %>
                        <button class="btn btn-sm" onclick="unequipItem('<%= item.item_type %>')"><i data-lucide="x"></i> Unequip</button>
                      <% } else { %>
                        <button class="btn btn-sm btn-primary" onclick="equipItem(<%= item.id %>)"><i data-lucide="check"></i> Equip</button>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>

            <% if (warnings && warnings.length > 0) { %>
            <div class="profile-section">
              <h2><i data-lucide="alert-triangle"></i> Warnings (<%= warnings.length %>)</h2>
              <div class="warning-list">
                <% warnings.forEach(w => { %>
                  <div class="warning-item">
                    <span class="warning-from">From <%= w.admin_name %>:</span>
                    <span class="warning-msg"><%= w.message %></span>
                    <span class="warning-date"><%= new Date(w.created_at).toLocaleDateString() %></span>
                  </div>
                <% }) %>
              </div>
            </div>
            <% } %>

            <div class="profile-section">
              <h2><i data-lucide="receipt"></i> Recent Transactions</h2>
              <% if (transactions.length === 0) { %>
                <%- include('partials/empty-state', { icon: 'receipt', title: 'No transactions yet', subtitle: '' }) %>
              <% } else { %>
                <div class="transaction-list">
                  <% transactions.forEach(tx => { %>
                    <div class="transaction <%= tx.amount > 0 ? 'positive' : 'negative' %>">
                      <span class="tx-reason"><%= tx.reason.replace(/_/g, ' ') %></span>
                      <span class="tx-amount"><%= tx.amount > 0 ? '+' : '' %><%= tx.amount %></span>
                      <span class="tx-date"><%= new Date(tx.created_at).toLocaleDateString() %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/main.js"></script>
</body>
</html>
