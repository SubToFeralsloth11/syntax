      <a href="/quests" class="sidebar-link<%= _p.startsWith('/quests') ? ' active' : '' %>"><i data-lucide="target"></i><span>Quests</span></a>
      <a href="/leaderboard" class="sidebar-link<%= _p.startsWith('/leaderboard') ? ' active' : '' %>"><i data-lucide="trophy"></i><span>Leaderboard</span></a>
