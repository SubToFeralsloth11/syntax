<% if (typeof unreadWarnings !== 'undefined' && unreadWarnings.length > 0) { %>
<div class="warning-overlay" id="warningOverlay">
  <div class="warning-modal">
    <div class="warning-modal-header">
      <span class="warning-modal-icon"><i data-lucide="alert-triangle"></i></span>
      <h2>Official Warning</h2>
    </div>
    <div class="warning-modal-body">
      <p class="warning-modal-blurb">You have received the following warning(s) from site administration. Continued violations may result in a permanent ban.</p>
      <% unreadWarnings.forEach(w => { %>
        <div class="warning-modal-item" data-warnid="<%= w.id %>">
          <div class="warning-modal-from">From: <strong><%= w.admin_name %></strong> &mdash; <%= new Date(w.created_at).toLocaleDateString() %></div>
          <div class="warning-modal-msg"><%= w.message %></div>
        </div>
      <% }) %>
    </div>
    <div class="warning-modal-footer">
      <p class="warning-ack-text">By dismissing this warning, you acknowledge that you have read and understood it.</p>
      <button class="btn btn-danger btn-lg" onclick="dismissAllWarnings()"><i data-lucide="check"></i> I Understand &mdash; Dismiss</button>
    </div>
  </div>
</div>
<script>
function dismissAllWarnings() {
  const items = document.querySelectorAll('.warning-modal-item');
  let done = 0;
  const total = items.length;
  items.forEach(el => {
    const id = el.dataset.warnid;
    fetch('/dismiss-warning', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ warningId: parseInt(id) })
    }).then(r => r.json()).then(data => {
      done++;
      if (done >= total) {
        const overlay = document.getElementById('warningOverlay');
        overlay.style.opacity = '0';
        setTimeout(() => overlay.remove(), 400);
      }
    });
  });
}
</script>
<% } %>

<% var _p = typeof currentPath !== 'undefined' ? currentPath : ''; %>
<header class="site-header">
  <div class="container">
    <a href="/" class="logo" aria-label="Syntax home"><img src="/images/logo.png?v=2" alt="Syntax" class="logo-img"></a>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false" onclick="toggleNav()">
      <span></span><span></span><span></span>
    </button>
    <nav class="nav" id="mainNav" aria-label="Primary">
      <a href="/" aria-current="<%= _p === '/' ? 'page' : 'false' %>"><i data-lucide="home"></i>Home</a>
      <a href="/games" aria-current="<%= _p.startsWith('/games') ? 'page' : 'false' %>"><i data-lucide="gamepad-2"></i>Games</a>
      <a href="/quests" aria-current="<%= _p.startsWith('/quests') ? 'page' : 'false' %>"><i data-lucide="target"></i>Quests</a>
      <a href="/leaderboard" aria-current="<%= _p.startsWith('/leaderboard') ? 'page' : 'false' %>"><i data-lucide="trophy"></i>Ranks</a>
      <a href="/earn" aria-current="<%= _p.startsWith('/earn') ? 'page' : 'false' %>"><i data-lucide="coins"></i>Earn</a>
      <a href="/trades" aria-current="<%= _p.startsWith('/trades') ? 'page' : 'false' %>"><i data-lucide="repeat"></i>Trades</a>
      <a href="/refer" aria-current="<%= _p.startsWith('/refer') ? 'page' : 'false' %>"><i data-lucide="gift"></i>Refer</a>
      <a href="/friends" aria-current="<%= _p.startsWith('/friends') || _p.startsWith('/profile/') ? 'page' : 'false' %>"><i data-lucide="users"></i>Friends</a>
      <a href="/chat" aria-current="<%= _p.startsWith('/chat') ? 'page' : 'false' %>"><i data-lucide="message-square"></i>Chat</a>
    </nav>
    <div class="user-section">
      <% if (typeof user !== 'undefined' && user) { %>
        <span class="coins-display" aria-label="Coins: <%= user.coins %>"><i data-lucide="circle-dollar-sign"></i><%= user.coins %></span>
        <% if (user.role === 'admin') { %>
          <a href="/admin" class="btn btn-sm admin-nav-btn"><i data-lucide="shield"></i>Admin</a>
        <% } %>
        <a href="/settings" class="settings-link" title="Settings" aria-label="Settings">
          <img src="<%= avatarUrl(user.avatar) %>" alt="" class="avatar-small" onerror="this.onerror=null;this.src='/images/default-avatar.svg'">
        </a>
        <a href="/profile" class="profile-link">
          <%= user.display_name %>
          <% if (user.role === 'admin') { %>
            <span class="owner-badge">Owner</span>
          <% } %>
        </a>
        <a href="/logout" class="btn btn-sm" aria-label="Logout"><i data-lucide="log-out"></i></a>
      <% } else { %>
        <a href="/login" class="btn btn-sm"><i data-lucide="log-in"></i>Login</a>
        <a href="/signup" class="btn btn-sm btn-primary">Sign Up</a>
      <% } %>
    </div>
  </div>
</header>
