<% if (typeof unreadWarnings !== 'undefined' && unreadWarnings.length > 0) { %>
<div class="warning-banner">
  <div class="container">
    <% unreadWarnings.forEach(w => { %>
      <div class="warning-banner-item" data-warnid="<%= w.id %>">
        <span class="warning-banner-icon">&#9888;</span>
        <span class="warning-banner-text"><strong><%= w.admin_name %></strong>: <%= w.message %></span>
        <span class="warning-banner-date"><%= new Date(w.created_at).toLocaleDateString() %></span>
        <button class="warning-dismiss" onclick="dismissWarning(<%= w.id %>, this.parentElement)" title="Dismiss">&times;</button>
      </div>
    <% }) %>
  </div>
</div>
<script>
function dismissWarning(id, el) {
  fetch('/dismiss-warning', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ warningId: id })
  }).then(r => r.json()).then(data => {
    if (data.success) {
      el.style.opacity = '0';
      el.style.transform = 'translateX(20px)';
      setTimeout(() => el.remove(), 300);
      const banner = document.querySelector('.warning-banner');
      if (banner && !banner.querySelector('.warning-banner-item')) {
        banner.style.opacity = '0';
        setTimeout(() => banner.remove(), 300);
      }
    }
  });
}
</script>
<% } %>

<header class="site-header">
  <div class="container">
    <a href="/" class="logo"><img src="/images/logo.svg" alt="Syntax" class="logo-img"></a>
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/games">Games</a>
      <a href="/shop">Shop</a>
      <a href="/bank">Bank</a>
      <a href="/trivia">Trivia</a>
      <a href="/wheel">Wheel</a>
      <a href="/leaderboard">Leaderboard</a>
      <a href="/chat">Chat</a>
      <a href="/refer">Refer</a>
    </nav>
    <div class="user-section">
      <% if (typeof user !== 'undefined' && user) { %>
        <span class="coins-display"><%= user.coins %> coins</span>
        <% if (user.role === 'admin') { %>
          <a href="/admin" class="btn btn-sm btn-glow admin-nav-btn">Admin</a>
        <% } %>
        <a href="/settings" class="settings-link" title="Settings">
          <img src="<%= avatarUrl(user.avatar) %>" alt="" class="avatar-small" onerror="this.onerror=null;this.src='/images/default-avatar.svg'">
        </a>
        <a href="/profile" class="profile-link">
          <%= user.display_name %>
          <% if (user.role === 'admin') { %>
            <span class="owner-badge" title="Owner">Owner</span>
          <% } %>
        </a>
        <a href="/logout" class="btn btn-sm">Logout</a>
      <% } else { %>
        <a href="/login" class="btn btn-sm">Login</a>
        <a href="/signup" class="btn btn-sm btn-primary">Sign Up</a>
      <% } %>
    </div>
  </div>
</header>
