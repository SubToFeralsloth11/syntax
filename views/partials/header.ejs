<!-- Toast notification container -->
<div class="toast-container" id="toastContainer"></div>

<% if (typeof user !== 'undefined' && user) { %>
<script>
(function(){
  var _lastChat = 0;
  var _lastFriendCount = 0;
  var _lastDMCount = 0;
  var _toasts = {};
  var _container = document.getElementById('toastContainer');

  function createIcon(type) {
    var svg = '';
    if (type === 'chat') svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>';
    else if (type === 'friend') svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>';
    else if (type === 'dm') svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>';
    return svg;
  }

  function showToast(type, title, msg, link) {
    var id = type + '-' + Date.now();
    var el = document.createElement('div');
    el.className = 'toast toast-' + type;
    el.id = id;
    el.innerHTML = '<div class="toast-icon">' + createIcon(type) + '</div>' +
      '<div class="toast-body"><div class="toast-title">' + title + '</div>' +
      '<div class="toast-msg">' + msg + '</div></div>' +
      '<button class="toast-dismiss" onclick="dismissToast(\'' + id + '\')">' +
      '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>';

    if (link) el.onclick = function(e) { if (!e.target.closest('.toast-dismiss')) window.location.href = link; };

    _container.appendChild(el);
    requestAnimationFrame(function() { el.classList.add('show'); });

    setTimeout(function() { dismissToast(id); }, 5000);
  }

  window.dismissToast = function(id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('show');
    el.classList.add('hide');
    setTimeout(function() { el.remove(); }, 350);
  };

  function updateBadges(data) {
    var fb = document.getElementById('badge-friends');
    var cb = document.getElementById('badge-chat');
    if (data.friends > 0) {
      if (!fb) { fb = document.createElement('span'); fb.className = 'sidebar-badge'; fb.id = 'badge-friends'; fb.style.display = ''; var fl = document.querySelector('a[href="/friends"]'); if (fl) fl.appendChild(fb); }
      fb.textContent = data.friends;
      fb.style.display = '';
    } else if (fb) { fb.style.display = 'none'; }

    if (data.chat > 0) {
      if (!cb) { cb = document.createElement('span'); cb.className = 'sidebar-badge'; cb.id = 'badge-chat'; cb.style.display = ''; var cl = document.querySelector('a[href="/chat"]'); if (cl) cl.appendChild(cb); }
      cb.textContent = data.chat;
      cb.style.display = '';
    } else if (cb) { cb.style.display = 'none'; }

    if (data.dms > 0 && data.dms > _lastDMCount) {
      showToast('dm', 'New Message', 'You have ' + data.dms + ' unread message(s)', '/friends');
    }
    if (data.friends > _lastFriendCount && _lastFriendCount > 0) {
      showToast('friend', 'Friend Request', 'You have a new friend request!', '/friends');
    }
    if (data.chat > _lastChat && _lastChat > 0 && !_chatPage) {
      showToast('chat', 'Chat', 'New messages in chat', '/chat');
    }

    _lastChat = data.chat;
    _lastFriendCount = data.friends;
    _lastDMCount = data.dms;
  }

  var _chatPage = window.location.pathname.startsWith('/chat');

  function poll() {
    fetch('/api/notifications', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(updateBadges)
      .catch(function(){});
  }

  poll();
  setInterval(poll, 8000);

  if (_chatPage) {
    fetch('/api/notifications/read-chat', { method: 'POST', credentials: 'same-origin' }).catch(function(){});
  }
})();
</script>
<% } %>
