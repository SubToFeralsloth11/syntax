<% if (typeof unreadWarnings !== 'undefined' && unreadWarnings.length > 0) { %>
<div class="warning-overlay" id="warningOverlay">
  <div class="warning-modal">
    <div class="warning-modal-header">
      <span class="warning-modal-icon"><i data-lucide="alert-triangle"></i></span>
      <h2>Official Warning</h2>
    </div>
    <div class="warning-modal-body">
      <p class="warning-modal-blurb">You have received the following warning(s) from site administration. Continued violations may result in a permanent ban.</p>
      <% unreadWarnings.forEach(w => { %>
        <div class="warning-modal-item" data-warnid="<%= w.id %>">
          <div class="warning-modal-from">From: <strong><%= w.admin_name %></strong> &mdash; <%= new Date(w.created_at).toLocaleDateString() %></div>
          <div class="warning-modal-msg"><%= w.message %></div>
        </div>
      <% }) %>
    </div>
    <div class="warning-modal-footer">
      <p class="warning-ack-text">By dismissing this warning, you acknowledge that you have read and understood it.</p>
      <button class="btn btn-danger btn-lg" onclick="dismissAllWarnings()"><i data-lucide="check"></i> I Understand &mdash; Dismiss</button>
    </div>
  </div>
</div>
<script>
function dismissAllWarnings() {
  const items = document.querySelectorAll('.warning-modal-item');
  let done = 0;
  const total = items.length;
  items.forEach(el => {
    const id = el.dataset.warnid;
    fetch('/dismiss-warning', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ warningId: parseInt(id) })
    }).then(r => r.json()).then(data => {
      done++;
      if (done >= total) {
        const overlay = document.getElementById('warningOverlay');
        overlay.style.opacity = '0';
        setTimeout(() => overlay.remove(), 400);
      }
    });
  });
}
</script>
<% } %>

<% var _p = typeof currentPath !== 'undefined' ? currentPath : ''; %>

<!-- Slim top bar: logo + user actions only -->
<header class="site-header">
  <div class="header-bar">
    <button class="nav-toggle" id="navToggle" aria-label="Toggle sidebar" aria-expanded="false" onclick="toggleNav()">
      <span></span><span></span><span></span>
    </button>
    <a href="/" class="logo" aria-label="Syntax home"><img src="/images/logo.png?v=3" alt="Syntax" class="logo-img"></a>
    <div class="user-section">
      <% if (typeof user !== 'undefined' && user) { %>
        <span class="coins-display" aria-label="Coins: <%= user.coins %>"><i data-lucide="circle-dollar-sign"></i><%= user.coins %></span>
        <% if (user.role === 'admin') { %>
          <a href="/admin" class="btn btn-sm admin-nav-btn"><i data-lucide="shield"></i>Admin</a>
        <% } %>
        <a href="/settings" class="settings-link" title="Settings" aria-label="Settings">
          <img src="<%= avatarUrl(user.avatar) %>" alt="" class="avatar-small" onerror="this.onerror=null;this.src='/images/default-avatar.svg'">
        </a>
        <a href="/profile" class="profile-link">
          <%= user.display_name %>
          <% if (user.role === 'admin') { %>
            <span class="owner-badge">Owner</span>
          <% } %>
        </a>
        <a href="/logout" class="btn btn-sm" aria-label="Logout"><i data-lucide="log-out"></i></a>
      <% } else { %>
        <a href="/login" class="btn btn-sm"><i data-lucide="log-in"></i>Login</a>
        <a href="/signup" class="btn btn-sm btn-primary">Sign Up</a>
      <% } %>
    </div>
  </div>
</header>

<% if (typeof activeEvents !== 'undefined' && activeEvents.length > 0) { %>
<div class="event-banner-container">
  <% activeEvents.forEach(ev => { %>
    <% const data = JSON.parse(ev.data || '{}'); %>
    <div class="event-banner" id="eventBanner_<%= ev.event_key %>">
      <span class="event-banner-icon"><%= data.icon || '🎉' %></span>
      <span class="event-banner-text"><strong><%= ev.name %></strong> — <%= ev.description.substring(0, 80) %><%= ev.description.length > 80 ? '...' : '' %></span>
      <% if (ev.event_key === 'defeat_button') { %>
        <button class="btn btn-sm btn-primary event-banner-btn" onclick="joinDefeatButton()">CLICK!</button>
      <% } else if (ev.event_key === 'click_frenzy') { %>
        <button class="btn btn-sm btn-primary event-banner-btn" onclick="clickFrenzy()">CLICK!</button>
      <% } else if (ev.event_key === 'dice_roll') { %>
        <button class="btn btn-sm btn-primary event-banner-btn" onclick="rollDice()">ROLL</button>
      <% } else if (ev.event_key === 'rps_tournament') { %>
        <button class="btn btn-sm btn-primary event-banner-btn" onclick="showRPS()">PLAY RPS</button>
      <% } %>
      <button class="event-banner-close" onclick="this.parentElement.remove()">×</button>
    </div>
  <% }) %>
</div>
<% } %>

<script>
async function joinDefeatButton() {
  const res = await fetch('/api/events/click', { method: 'POST' });
  const data = await res.json();
  if (data.complete) {
    showNotification('🎉 Button defeated! You earned ' + data.reward + ' coins!', true);
  } else if (data.success) {
    showNotification('Clicked! Progress: ' + data.total + '/' + data.target + ' (' + data.progress + '%)', true);
  }
}

async function clickFrenzy() {
  const res = await fetch('/api/events/click-frenzy', { method: 'POST' });
  const data = await res.json();
  if (data.complete) {
    showNotification('🎉 Click Frenzy complete! +200 coins!', true);
  } else if (data.success) {
    showNotification('Clicks: ' + data.clicks + '/' + data.target, true);
  }
}

async function rollDice() {
  const res = await fetch('/api/events/roll-dice', { method: 'POST' });
  const data = await res.json();
  if (data.won) {
    showNotification('🎲 You rolled a ' + data.roll + '! +' + data.reward + ' coins!', true);
  } else {
    showNotification('🎲 You rolled a ' + data.roll + '. Try again!', false);
  }
}

function showRPS() {
  const choice = prompt('Choose: rock, paper, or scissors?');
  if (!choice) return;
  fetch('/api/events/rps', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ choice: choice.toLowerCase() })
  }).then(r => r.json()).then(data => {
    if (data.won) {
      showNotification('✊ ' + data.choice + ' vs ' + data.cpu + ' — WIN! Streak: ' + data.streak + '/' + data.target, true);
    } else {
      showNotification('✊ ' + data.choice + ' vs ' + data.cpu + ' — ' + data.result.toUpperCase() + '. Streak reset.', false);
    }
  });
}
</script>

<style>
.event-banner-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9998;
  display: flex;
  flex-direction: column;
  pointer-events: none;
}
.event-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  background: linear-gradient(90deg, rgba(0,240,255,0.15), rgba(181,55,242,0.15), rgba(255,43,214,0.15));
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0,240,255,0.3);
  color: var(--text);
  font-size: 0.85rem;
  pointer-events: all;
  animation: eventSlide 0.3s ease;
}
@keyframes eventSlide {
  from { transform: translateY(-100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.event-banner-icon { font-size: 1.2rem; }
.event-banner-text { flex: 1; }
.event-banner-text strong { color: var(--cyan); }
.event-banner-btn {
  padding: 4px 12px;
  font-size: 0.75rem;
  font-weight: 700;
  animation: pulse 1.5s infinite;
}
.event-banner-close {
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 1.2rem;
  cursor: pointer;
  padding: 0 4px;
  line-height: 1;
}
.event-banner-close:hover { color: var(--text); }
</style>

