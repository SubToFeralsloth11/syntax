      <a href="/settings" class="sidebar-link<%= _p.startsWith('/settings') ? ' active' : '' %>"><i data-lucide="settings"></i><span>Settings</span></a>
    </div>

    <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
    <div class="sidebar-group">
      <span class="sidebar-label"><i data-lucide="shield"></i> Admin</span>
      <a href="/admin" class="sidebar-link<%= _p.startsWith('/admin') ? ' active' : '' %>"><i data-lucide="layout-dashboard"></i><span>Panel</span></a>
    </div>
    <% } %>
  </nav>
