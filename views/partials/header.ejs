      <a href="/wheel" class="sidebar-link<%= _p.startsWith('/wheel') ? ' active' : '' %>"><i data-lucide="disc-3"></i><span>Lucky Wheel</span></a>
      <a href="/lottery" class="sidebar-link<%= _p.startsWith('/lottery') ? ' active' : '' %>"><i data-lucide="ticket"></i><span>Lottery</span></a>
      <a href="/trivia" class="sidebar-link<%= _p.startsWith('/trivia') ? ' active' : '' %>"><i data-lucide="brain-circuit"></i><span>Trivia</span></a>
      <a href="/trades" class="sidebar-link<%= _p.startsWith('/trades') ? ' active' : '' %>"><i data-lucide="repeat"></i><span>Trades</span></a>
