<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // ' + game.name }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="game-detail-page">
      <div class="container">
        <a href="/games" class="btn back-link"><i data-lucide="arrow-left"></i> Back to Games</a>
        <div class="game-detail-card">
          <div class="game-detail-icon"><%= game.name[0] %></div>
          <h1><%= game.name %></h1>
          <p class="game-detail-desc"><%= game.description %></p>

          <% if (game.status === 'coming-soon') { %>
            <div class="coming-soon-banner">
              <h2><i data-lucide="clock"></i> Coming Soon</h2>
              <p>This game is being built. Check back later!</p>
            </div>
          <% } else { %>
            <% if (playedToday) { %>
              <p class="played-msg"><i data-lucide="check-circle"></i> You've played this game today</p>
            <% } else { %>
              <button class="btn btn-primary btn-lg" onclick="playGame('<%= game.id %>')"><i data-lucide="play"></i> Play Now</button>
            <% } %>
          <% } %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/main.js"></script>
</body>
</html>
