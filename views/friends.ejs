<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Friends — Syntax' }) %>
<body>
  <%- include('partials/header') %>
  <main>
    <section class="page-header">
      <div class="container"><h1>Friends</h1></div>
    </section>
    <section class="friends-section">
      <div class="container">
        <% if (pendingReceived.length > 0) { %>
          <h2><i data-lucide="inbox"></i> Requests (<%= pendingReceived.length %>)</h2>
          <div class="friend-list">
            <% pendingReceived.forEach(r => { %>
              <div class="friend-row">
                <a href="/profile/<%= r.id %>"><%= r.display_name %></a>
                <span class="mono">Level <%= r.level %></span>
                <button class="btn btn-sm btn-primary" onclick="acceptRequest(<%= r.id %>)"><i data-lucide="check"></i> Accept</button>
                <button class="btn btn-sm" onclick="rejectRequest(<%= r.id %>)"><i data-lucide="x"></i> Reject</button>
              </div>
            <% }) %>
          </div>
        <% } %>
        <h2><i data-lucide="users"></i> Friends (<%= friends.length %>)</h2>
        <% if (friends.length === 0) { %>
          <%- include('partials/empty-state', { icon: 'user-x', title: 'No friends yet. Visit someone\'s profile to add them!', subtitle: '' }) %>
        <% } else { %>
          <div class="friend-list">
            <% friends.forEach(f => { %>
              <div class="friend-row">
                <a href="/profile/<%= f.id %>"><%= f.display_name %></a>
                <span class="mono">Level <%= f.level %></span>
                <span class="online-dot <%= (f.last_active && (Date.now() - new Date(f.last_active).getTime()) < 300000) ? 'online' : '' %>"></span>
                <button class="btn btn-sm btn-primary" onclick="openDM(<%= f.id %>,'<%= f.display_name.replace(/'/g,"\\\\\'") %>')"><i data-lucide="message-circle"></i> Message</button>
                <button class="btn btn-sm btn-danger-outline" onclick="removeFriend(<%= f.id %>)"><i data-lucide="user-minus"></i> Remove</button>
              </div>
            <% }) %>
          </div>
        <% } %>
        <div class="modal-overlay hidden" id="dmOverlay">
          <div class="modal" style="max-width:520px" role="dialog" aria-modal="true" aria-label="Direct messages">
            <div class="modal-header">
              <h2 id="dmTitle">Message</h2>
              <button class="modal-close" onclick="closeDM()" aria-label="Close"><i data-lucide="x"></i></button>
            </div>
            <div class="modal-body">
              <div class="dm-messages" id="dmMessages"></div>
              <div class="dm-input">
                <input type="text" id="dmInput" placeholder="Type a message..." style="flex:1" maxlength="500">
                <button class="btn btn-primary btn-sm" onclick="sendDM()"><i data-lucide="send"></i></button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script src="/js/main.js"></script>
  <script>
    var dmFriendId = null;
    var dmInterval = null;
    function acceptRequest(id) { fetch('/friends/accept',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({requestId:id})}).then(r=>r.json()).then(d=>{showNotification(d.message,d.success!==false);if(d.success||d.message)location.reload()}) }
    function rejectRequest(id) { fetch('/friends/reject',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({requestId:id})}).then(r=>r.json()).then(d=>{showNotification(d.message,d.success!==false);if(d.success||d.message)location.reload()}) }
    function removeFriend(id) { if(confirm('Remove friend?')){fetch('/friends/remove',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({friendId:id})}).then(r=>r.json()).then(d=>{showNotification(d.message,d.success!==false);if(d.success||d.message)location.reload()})} }
    function openDM(id,name) {
      dmFriendId = id;
      document.getElementById('dmTitle').textContent = 'DM: ' + name;
      document.getElementById('dmOverlay').classList.remove('hidden');
      loadDMs();
      dmInterval = setInterval(loadDMs, 3000);
    }
    function closeDM() { document.getElementById('dmOverlay').classList.add('hidden'); dmFriendId = null; if(dmInterval)clearInterval(dmInterval); }
    function loadDMs() {
      if(!dmFriendId) return;
      fetch('/friends/dm/'+dmFriendId).then(r=>r.json()).then(data=>{
        var el = document.getElementById('dmMessages');
        el.innerHTML = data.dms.map(m=>'<div class="dm-msg"><strong>'+m.from_name+':</strong> '+m.message+' <small>'+new Date(m.created_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})+'</small></div>').join('');
        el.scrollTop = el.scrollHeight;
      });
    }
    function sendDM() {
      var msg = document.getElementById('dmInput').value.trim();
      if(!msg || !dmFriendId) return;
      fetch('/friends/dm',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({friendId:dmFriendId,message:msg})}).then(r=>r.json()).then(d=>{
        if(d.success) { document.getElementById('dmInput').value = ''; loadDMs(); } else showNotification(d.message,false);
      });
    }
    <% if (typeof query !== 'undefined' && query.dm) { %>setTimeout(function(){ openDM(<%= query.dm %>, 'Friend'); }, 500);<% } %>
  </script>
</body>
</html>
