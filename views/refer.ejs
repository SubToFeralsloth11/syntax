<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'SYNTAX // Refer' }) %>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1>Refer a Friend</h1>
        <p>Share your link and earn 100 coins for each friend who joins (max <%= maxReferrals %>)</p>
      </div>
    </section>

    <section class="refer-section">
      <div class="container">
        <div class="refer-card">
          <h2><i data-lucide="link"></i> Your Referral Link</h2>
          <div class="ref-link-box">
            <input type="text" id="refLink" value="<%= `${process.env.BASE_URL || 'http://localhost:3000'}/ref/${refCode}` %>" readonly>
            <button class="btn btn-primary" onclick="copyRefLink()" id="copyBtn"><i data-lucide="copy"></i> Copy</button>
          </div>
          <p class="ref-earnings">
            <i data-lucide="coins" style="width:14px;height:14px"></i>
            You've earned <strong><%= totalEarned %></strong> coins from <strong><%= Math.min(referralCount, maxReferrals) %></strong> referral(s)
            <% if (referralCount >= maxReferrals) { %>
              — max reached!
            <% } else if (referralCount > 0) { %>
              (<%= maxReferrals - referralCount %> left)
            <% } %>
          </p>

          <% if (referrals.length > 0) { %>
            <div class="referral-list">
              <h3>Your Referrals</h3>
              <% referrals.forEach(r => { %>
                <div class="referral-item">
                  <span><i data-lucide="user"></i> <%= r.display_name %></span>
                  <span class="ref-date"><%= new Date(r.created_at).toLocaleDateString() %></span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <%- include('partials/empty-state', { icon: 'user-plus', title: 'No referrals yet. Share your link to start earning!', subtitle: '' }) %>
          <% } %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/notification') %>
  <script>
    function copyRefLink() {
      var input = document.getElementById('refLink');
      input.select();
      input.setSelectionRange(0, 99999);
      navigator.clipboard.writeText(input.value).then(function() {
        var btn = document.getElementById('copyBtn');
        btn.innerHTML = '<i data-lucide="check"></i> Copied!';
        if (window.lucide) lucide.createIcons();
        setTimeout(function() { btn.innerHTML = '<i data-lucide="copy"></i> Copy'; if (window.lucide) lucide.createIcons(); }, 2000);
      }).catch(function() {
        showNotification('Failed to copy. Please copy manually.', false);
      });
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
